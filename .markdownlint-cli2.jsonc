{
  // markdownlint-cli2 config for the Q-Summit docs. Basic and non-annoying.
  // Rule reference: https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md
  "config": {
    "default": true,

    // MD013 (line length): prose is never hard-wrapped by width here
    // (prettier proseWrap:never), so a max line length would fight our style.
    "MD013": false,

    // MD033 (inline HTML): the only angle brackets in our Markdown are HTML
    // comments (<!-- ... -->) and <placeholder> markers in the sketch/ADR
    // templates; neither is real inline HTML we need to guard against.
    "MD033": false,

    // MD025 / MD041 (headings vs. front matter): sketches carry a `title:` in
    // YAML front matter AND a real "# NNNN · ..." H1. The front-matter title is
    // metadata for the docs validator, not a rendered heading, so tell both
    // rules to ignore it; otherwise the real H1 reads as a duplicate H1.
    "MD025": { "front_matter_title": "" },
    "MD041": { "front_matter_title": "" }
  },
  "globs": ["**/*.md"],
  // node_modules: dependencies. LICENSE/COMMERCIAL/CLA: legal text kept
  // byte-for-byte (also prettier-ignored); we do not restyle it.
  // AGENTS.md / CLAUDE.md: agent guides (root and nested); CLAUDE.md starts
  // with the @AGENTS.md import line, which is not an H1.
  "ignores": [".agents", ".claude", "**/AGENTS.md", "**/CLAUDE.md", "node_modules", "LICENSE.md", "COMMERCIAL.md", "CLA.md"]
}
