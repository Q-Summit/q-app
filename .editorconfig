# Editor defaults for all contributors; Prettier enforces the same style on
# the files it formats. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Trailing double-space is a hard line break in Markdown; let Prettier decide.
[*.md]
trim_trailing_whitespace = false
